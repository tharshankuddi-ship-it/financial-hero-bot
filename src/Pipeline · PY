# Background music — synthesised with numpy, zero downloads
# ══════════════════════════════════════════════════════════════════════════════

def _generate_bg_music(duration: float, output_path: str, volume: float = 0.08) -> str:
    """
    Synthesise a soft ambient finance beat using numpy.
    Layers: sub bass pulse + pad chord + high shimmer.
    All at very low volume so it sits under the voice.
    """
    sr        = 44100
    n         = int(sr * duration)
    t         = np.linspace(0, duration, n, endpoint=False)
    bpm       = 90
    beat_hz   = bpm / 60.0

    # Sub bass kick — decays each beat
    kick_env = np.exp(-8 * (t % (1 / beat_hz)))
    kick     = np.sin(2 * np.pi * 60 * t) * kick_env * 0.6

    # Pad chord: A minor feel (220 / 261 / 330 Hz) with slow swell
    pad_env = 0.5 + 0.5 * np.sin(2 * np.pi * 0.25 * t)
    pad     = (
        np.sin(2 * np.pi * 220 * t) * 0.35 +
        np.sin(2 * np.pi * 261 * t) * 0.25 +
        np.sin(2 * np.pi * 330 * t) * 0.20
    ) * pad_env

    # Shimmer — every 2 beats
    shimmer_env = np.exp(-16 * (t % (2 / beat_hz)))
    shimmer     = np.sin(2 * np.pi * 880 * t) * shimmer_env * 0.15

    mix = (kick + pad + shimmer) * volume
    mix = np.tanh(mix * 3) / 3          # soft limiter

    # Fade in / out 0.5 s
    fade = int(sr * 0.5)
    mix[:fade]  *= np.linspace(0, 1, fade)
    mix[-fade:] *= np.linspace(1, 0, fade)

    pcm      = (mix * 32767).astype(np.int16)
    wav_path = output_path.replace(".mp3", "_bg.wav")
    with wave.open(wav_path, "w") as wf:
        wf.setnchannels(1)
        wf.setsampwidth(2)
        wf.setframerate(sr)
        wf.writeframes(pcm.tobytes())

    subprocess.run(
        ["ffmpeg", "-i", wav_path, "-q:a", "4", output_path, "-y"],
        capture_output=True, timeout=30,
    )
    try: os.unlink(wav_path)
    except OSError: pass
    log.info(f"BG music: {duration:.1f}s")
    return output_path


def _mix_audio(voice_path: str, music_path: str,
               output_path: str, music_vol: float = 0.10) -> str:
    """Mix voice (full vol) + background music (ducked to music_vol)."""
    r = subprocess.run([
        "ffmpeg", "-y",
        "-i", voice_path,
        "-i", music_path,
        "-filter_complex",
        (f"[1:a]volume={music_vol}[bg];"
         "[0:a][bg]amix=inputs=2:duration=first:dropout_transition=2[out]"),
        "-map", "[out]",
        "-q:a", "2",
        output_path,
    ], capture_output=True, timeout=60)

    if r.returncode != 0:
        log.warning(f"Mix failed — using voice only: {r.stderr.decode()[:120]}")
        import shutil; shutil.copy(voice_path, output_path)

    log.info(f"Mixed audio → {output_path}")
    return output_path


# ══════════════════════════════════════════════════════════════════════════════
# TTS
# ══════════════════════════════════════════════════════════════════════════════

def generate_audio(
    script: str,
    output_path: str,
    engine: str                = "gtts",
    voice: str                 = "en-us",
    speed: int                 = 148,
    elevenlabs_key: str | None = None,
    add_music: bool            = True,
) -> str:
    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
    voice_path = output_path.replace(".mp3", "_voice.mp3")

    if engine == "elevenlabs" and elevenlabs_key:
        _elevenlabs_tts(script, voice_path, elevenlabs_key)
    elif engine == "gtts":
        _gtts_tts(script, voice_path)
    else:
        _espeak_tts(script, voice_path, voice=voice, speed=speed)

    if add_music:
        dur        = _get_audio_duration(voice_path)
        music_path = output_path.replace(".mp3", "_bgmusic.mp3")
        _generate_bg_music(dur + 1.0, music_path)
        _mix_audio(voice_path, music_path, output_path)
        for p in (voice_path, music_path):
            try: os.unlink(p)
            except OSError: pass
    else:
        import shutil; shutil.move(voice_path, output_path)

    log.info(f"Audio ready: {_get_audio_duration(output_path):.1f}s → {output_path}")
    return output_path


def _gtts_tts(script: str, path: str) -> str:
    try:
        from gtts import gTTS
        gTTS(script, lang="en", slow=False).save(path)
        log.info("gTTS voice generated")
        return path
    except Exception as e:
        log.warning(f"gTTS failed ({e}) — espeak fallback")
        return _espeak_tts(script, path)


def _espeak_tts(script: str, path: str, voice: str = "en-us", speed: int = 148) -> str:
    with tempfile.NamedTemporaryFile(mode="w", suffix=".txt", delete=False) as f:
        f.write(script); txt = f.name
    wav = path.replace(".mp3", "_esp.wav")
    try:
        subprocess.run(
            ["espeak-ng", "-v", voice, "-s", str(speed), "-p", "40", "-f", txt, "-w", wav],
            capture_output=True, text=True, timeout=60, check=True,
        )
        subprocess.run(
            ["ffmpeg", "-i", wav, "-q:a", "2", path, "-y"],
            capture_output=True, timeout=30, check=True,
        )
        log.info("espeak-ng voice generated")
        return path
    finally:
        for p in (txt, wav):
            try: os.unlink(p)
            except OSError: pass


def _elevenlabs_tts(script: str, path: str, api_key: str) -> str:
    import urllib.request, json as _json
    VOICE_ID = "pNInz6obpgDQGcFmaJgB"
    req = urllib.request.Request(
        f"https://api.elevenlabs.io/v1/text-to-speech/{VOICE_ID}",
        data=_json.dumps({
            "text": script, "model_id": "eleven_monolingual_v1",
            "voice_settings": {"stability": 0.5, "similarity_boost": 0.75},
        }).encode(),
        headers={"xi-api-key": api_key, "Content-Type": "application/json",
                 "Accept": "audio/mpeg"},
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            open(path, "wb").write(resp.read())
        log.info("ElevenLabs voice generated")
        return path
    except Exception as e:
        log.warning(f"ElevenLabs failed ({e}) — gtts fallback")
        return _gtts_tts(script, path)


def _get_audio_duration(path: str) -> float:
    r = subprocess.run(
        ["ffprobe", "-v", "quiet", "-show_entries", "format=duration",
         "-of", "default=noprint_wrappers=1:nokey=1", path],
        capture_output=True, text=True,
    )
    try:    return float(r.stdout.strip())
    except: return 0.0


# ══════════════════════════════════════════════════════════════════════════════
# Full pipeline
# ══════════════════════════════════════════════════════════════════════════════

def run(
    topic: str                  = None,
    auto: bool                  = False,
    script: str | None          = None,
    out_dir: str                = "output",
    voice: str                  = "en-us",
    speed: int                  = 148,
    tts_engine: str             = "gtts",
    add_music: bool             = True,
    thumb_style: str            = "split",
    thumb_seed: int             = None,
    font_path: str | None       = None,
    api_key: str | None         = None,
    elevenlabs_key: str | None  = None,
) -> dict[str, str]:

    t0 = time.time()
    os.makedirs(out_dir, exist_ok=True)

    if auto or not topic:
        topic = pick_topic(out_dir)
    if thumb_seed is None:
        thumb_seed = random.randint(1, 9999)

    slug  = re.sub(r"[^a-z0-9]+", "_", topic.lower()).strip("_")[:50]
    paths = {
        "script":    os.path.join(out_dir, f"{slug}_script.txt"),
        "audio":     os.path.join(out_dir, f"{slug}_audio.mp3"),
        "video":     os.path.join(out_dir, f"{slug}_video.mp4"),
        "thumbnail": os.path.join(out_dir, f"{slug}_thumbnail.png"),
    }

    log.info("━━ 1/4 Script")
    if not script:
        script = generate_script(topic, api_key)
    Path(paths["script"]).write_text(script)
    log.info(f"   {len(script.split())} words")

    log.info("━━ 2/4 Audio")
    generate_audio(script, paths["audio"],
                   engine=tts_engine, voice=voice, speed=speed,
                   elevenlabs_key=elevenlabs_key, add_music=add_music)
    duration = _get_audio_duration(paths["audio"])

    log.info("━━ 3/4 Video")
    sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
    from editor import render_video
    render_video(script=script, audio_path=paths["audio"],
                 output_path=paths["video"], font_path=font_path)
    video_mb = os.path.getsize(paths["video"]) / 1024 / 1024

    log.info("━━ 4/4 Thumbnail")
    from editor import generate_thumbnail
    generate_thumbnail(title=topic, output_path=paths["thumbnail"],
                       style=thumb_style, seed=thumb_seed)

    elapsed = time.time() - t0
    _print_summary(topic, paths, duration, video_mb, elapsed)
    return paths


def _print_summary(topic, paths, duration, video_mb, elapsed):
    print("\n" + "═" * 60)
    print("  ✅  Financial Hero Pipeline Complete")
    print("═" * 60)
    print(f"  Topic    : {topic[:56]}")
    print(f"  Duration : {duration:.1f}s  |  Video: {video_mb:.1f}MB  |  Time: {elapsed:.0f}s")
    print("─" * 60)
    for icon, label, key in [("📝","Script   ","script"),("🔊","Audio    ","audio"),
                               ("🎬","Video    ","video"),("🖼 ","Thumbnail","thumbnail")]:
        print(f"  {icon} {label}: {paths[key]}")
    print("═" * 60 + "\n")


# ══════════════════════════════════════════════════════════════════════════════
# CLI
# ══════════════════════════════════════════════════════════════════════════════

def main():
    p = argparse.ArgumentParser(
        description="Financial Hero — YouTube Shorts Pipeline",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""
            Examples:
              python pipeline.py --auto                          # fresh unique topic
              python pipeline.py --topic "Compound interest"    # specific topic
              python pipeline.py --auto --api-key sk-ant-...    # AI script
              python pipeline.py --auto --no-music              # no background beat
              python pipeline.py --auto --tts elevenlabs --el-key KEY
        """),
    )
    p.add_argument("--auto",     action="store_true", help="Auto-pick unused topic")
    p.add_argument("--topic",    default=None)
    p.add_argument("--script",   default=None)
    p.add_argument("--out",      default="output")
    p.add_argument("--tts",      default="gtts", choices=["gtts","espeak","elevenlabs"])
    p.add_argument("--voice",    default="en-us")
    p.add_argument("--speed",    default=148, type=int)
    p.add_argument("--no-music", action="store_true")
    p.add_argument("--style",    default="split", choices=["split","dramatic","youtube"])
    p.add_argument("--seed",     default=None, type=int)
    p.add_argument("--font",     default=None)
    p.add_argument("--api-key",  default=os.getenv("ANTHROPIC_API_KEY"))
    p.add_argument("--el-key",   default=os.getenv("ELEVENLABS_API_KEY"))
    p.add_argument("--verbose","-v", action="store_true")
    args = p.parse_args()

    if not args.auto and not args.topic:
        p.error("Use --auto or --topic")

    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(asctime)s  %(levelname)-7s  %(message)s",
        datefmt="%H:%M:%S",
    )
    run(topic=args.topic, auto=args.auto, script=args.script,
        out_dir=args.out, voice=args.voice, speed=args.speed,
        tts_engine=args.tts, add_music=not args.no_music,
        thumb_style=args.style, thumb_seed=args.seed,
        font_path=args.font, api_key=args.api_key, elevenlabs_key=args.el_key)


if __name__ == "__main__":
    main()
