# CLI entry point
# ══════════════════════════════════════════════════════════════════════════════

def main():
    parser = argparse.ArgumentParser(
        description="Financial Hero — YouTube Shorts Pipeline",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""
            Examples:
              # Fastest (offline, no keys needed):
              python pipeline.py --topic "Why the rich get richer"

              # With AI script generation:
              python pipeline.py --topic "Inflation explained" --api-key sk-ant-...

              # With best quality voice (ElevenLabs free tier):
              python pipeline.py --topic "Stock market basics" --tts elevenlabs --el-key YOUR_KEY

              # Custom output directory:
              python pipeline.py --topic "Crypto wealth" --out /tmp/videos/
        """),
    )
    parser.add_argument("--topic",   required=True,         help="Video topic / title")
    parser.add_argument("--script",  default=None,          help="Custom script (skip generation)")
    parser.add_argument("--out",     default="output",      help="Output directory (default: output/)")
    parser.add_argument("--voice",   default="en-us",       help="espeak-ng voice (default: en-us)")
    parser.add_argument("--speed",   default=148, type=int, help="TTS speed WPM (default: 148)")
    parser.add_argument("--tts",     default="espeak",
                        choices=["espeak", "gtts", "elevenlabs"],
                        help="TTS engine (default: espeak)")
    parser.add_argument("--style",   default="split",
                        choices=["split", "dramatic", "youtube"],
                        help="Thumbnail style (default: split)")
    parser.add_argument("--seed",    default=42, type=int,  help="Thumbnail image seed (default: 42)")
    parser.add_argument("--font",    default=None,          help="Path to .ttf caption font")
    parser.add_argument("--api-key", default=os.getenv("ANTHROPIC_API_KEY"),
                        help="Anthropic API key for script gen (or set ANTHROPIC_API_KEY env var)")
    parser.add_argument("--el-key",  default=os.getenv("ELEVENLABS_API_KEY"),
                        help="ElevenLabs API key (or set ELEVENLABS_API_KEY env var)")
    parser.add_argument("--verbose", "-v", action="store_true", help="Show debug logs")

    args = parser.parse_args()

    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(asctime)s  %(levelname)-7s  %(message)s",
        datefmt="%H:%M:%S",
    )

    run(
        topic          = args.topic,
        script         = args.script,
        out_dir        = args.out,
        voice          = args.voice,
        speed          = args.speed,
        tts_engine     = args.tts,
        thumb_style    = args.style,
        thumb_seed     = args.seed,
        font_path      = args.font,
        api_key        = args.api_key,
        elevenlabs_key = args.el_key,
    )


if __name__ == "__main__":
    main()
