# Topic rotation
# ══════════════════════════════════════════════════════════════════════════════

def pick_topic(out_dir: str = "output") -> str:
    """
    Pick a topic not yet used. Tracks history in used_topics.json.
    Resets automatically once all 30 topics are exhausted.
    """
    os.makedirs(out_dir, exist_ok=True)
    tracker = os.path.join(out_dir, "used_topics.json")

    used: list[str] = []
    if os.path.exists(tracker):
        try:
            with open(tracker) as f:
                used = json.load(f)
        except Exception:
            used = []

    available = [t for t in TOPIC_POOL if t not in used]
    if not available:
        log.info("All 30 topics used — resetting rotation")
        used      = []
        available = list(TOPIC_POOL)

    topic = random.choice(available)
    used.append(topic)
    with open(tracker, "w") as f:
        json.dump(used, f, indent=2)

    log.info(f"Topic {len(used)}/{len(TOPIC_POOL)}: {topic}")
    return topic


# ══════════════════════════════════════════════════════════════════════════════
# Script generation
# ══════════════════════════════════════════════════════════════════════════════

def generate_script(topic: str, api_key: str | None = None) -> str:
    if api_key:
        return _claude_script(topic, api_key)
    return _template_script(topic)


def _claude_script(topic: str, api_key: str) -> str:
    import urllib.request, json as _json
    prompt = textwrap.dedent(f"""
        Write a punchy 60-second YouTube Shorts voiceover script about: "{topic}"
        Rules:
        - Finance / wealth mindset theme
        - 80-100 words total
        - No headers, no bullets — plain flowing sentences only
        - Hook in first 5 words to stop the scroll
        - End with a call-to-action
        - No hashtags, emojis, or stage directions
        Output ONLY the script text.
    """).strip()

    payload = _json.dumps({
        "model": "claude-haiku-4-5-20251001",
        "max_tokens": 300,
        "messages": [{"role": "user", "content": prompt}],
    }).encode()

    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=payload,
        headers={
            "x-api-key": api_key,
            "anthropic-version": "2023-06-01",
            "content-type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            data   = _json.loads(resp.read())
            script = data["content"][0]["text"].strip()
            log.info(f"Claude script: {len(script.split())} words")
            return script
    except Exception as e:
        log.warning(f"Claude API failed ({e}) — using template")
        return _template_script(topic)


def _template_script(topic: str) -> str:
    tl = topic.lower()
    for key, script in SCRIPT_TEMPLATES.items():
        if key != "default" and key in tl:
            log.info(f"Template: '{key}'")
            return script
    log.info("Default template")
    return SCRIPT_TEMPLATES["default"]


