def run(
    topic: str                  = None,
    auto: bool                  = False,
    script: str | None          = None,
    out_dir: str                = "output",
    voice: str                  = "en-us",
    speed: int                  = 148,
    tts_engine: str             = "gtts",
    add_music: bool             = True,
    thumb_style: str            = "split",
    thumb_seed: int             = None,
    font_path: str | None       = None,
    api_key: str | None         = None,
    elevenlabs_key: str | None  = None,
) -> dict[str, str]:

    t0 = time.time()
    os.makedirs(out_dir, exist_ok=True)

    if auto or not topic:
        topic = pick_topic(out_dir)
    if thumb_seed is None:
        thumb_seed = random.randint(1, 9999)

    slug  = re.sub(r"[^a-z0-9]+", "_", topic.lower()).strip("_")[:50]
    paths = {
        "script":    os.path.join(out_dir, f"{slug}_script.txt"),
        "audio":     os.path.join(out_dir, f"{slug}_audio.mp3"),
        "video":     os.path.join(out_dir, f"{slug}_video.mp4"),
        "thumbnail": os.path.join(out_dir, f"{slug}_thumbnail.png"),
    }

    log.info("━━ 1/4 Script")
    if not script:
        script = generate_script(topic, api_key)
    Path(paths["script"]).write_text(script)
    log.info(f"   {len(script.split())} words")

    log.info("━━ 2/4 Audio")
    generate_audio(script, paths["audio"],
                   engine=tts_engine, voice=voice, speed=speed,
                   elevenlabs_key=elevenlabs_key, add_music=add_music)
    duration = _get_audio_duration(paths["audio"])

    log.info("━━ 3/4 Video")
    sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
    from editor import render_video
    render_video(script=script, audio_path=paths["audio"],
                 output_path=paths["video"], font_path=font_path)
    video_mb = os.path.getsize(paths["video"]) / 1024 / 1024

    log.info("━━ 4/5 Thumbnail")
    from editor import generate_thumbnail
    generate_thumbnail(title=topic, output_path=paths["thumbnail"],
                       style=thumb_style, seed=thumb_seed)

    # ── 5. Duplicate check — skip upload if same topic posted recently ──────────
    log.info("━━ 5/5 Duplicate check + Upload")
    if _is_duplicate_title(topic, out_dir):
        log.warning(f"DUPLICATE: '{topic}' was recently posted — skipping upload")
        paths["uploads"] = {"all": "skipped — duplicate topic"}
    else:
        _record_posted_title(topic, out_dir)
        try:
            from uploader import upload_everywhere
            upload_results = upload_everywhere(
                video_path  = paths["video"],
                title       = topic,
                description = script[:200],
            )
            paths["uploads"] = upload_results
        except Exception as e:
            log.warning(f"Upload step failed: {e}")
            paths["uploads"] = {}

    elapsed = time.time() - t0
    _print_summary(topic, paths, duration, video_mb, elapsed)
    return paths


def _print_summary(topic, paths, duration, video_mb, elapsed):
    print("\n" + "═" * 60)
    print("  ✅  Financial Hero Pipeline Complete")
    print("═" * 60)
    print(f"  Topic    : {topic[:56]}")
    print(f"  Duration : {duration:.1f}s  |  Video: {video_mb:.1f}MB  |  Time: {elapsed:.0f}s")
    print("─" * 60)
    for icon, label, key in [("📝","Script   ","script"),("🔊","Audio    ","audio"),
                               ("🎬","Video    ","video"),("🖼 ","Thumbnail","thumbnail")]:
        print(f"  {icon} {label}: {paths[key]}")
